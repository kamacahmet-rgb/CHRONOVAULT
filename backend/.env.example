# backend/.env — kopyala: cp .env.example .env
APP_NAME=TurkDamga
APP_VERSION=0.1.0
DEBUG=false

# Boş bırakılabilir: /health yine 200 döner; "db": "skipped"
# Yerel Postgres örneği (infra/docker-compose ile uyumlu kullanıcı/DB adlarını uyarlayın):
# DATABASE_URL=postgresql+asyncpg://turkdamga:degistir_guclu_parola_en_az_24_karakter@127.0.0.1:5432/turkdamga

# Damga ↔ T.C. parmak izi (HMAC); üretimde güçlü rastgele değer
# SUBJECT_TC_HMAC_SECRET=

# Polygon GAS tahmini (cent); satış kredisi = bu değer × 10 (sabit ürün kuralı)
# POLYGON_GAS_COST_CENTS_ESTIMATE=1
# SIGNUP_BONUS_CREDITS=10000
